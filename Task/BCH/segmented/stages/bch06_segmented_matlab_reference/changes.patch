+    mdir=root/'Task/BCH/segmented/matlab'; command=f"addpath('{mdir.as_posix()}'); run_bch06_segmented_matlab_reference('', '{mat.as_posix()}');"
+    run([a.matlab_command,'-batch',command],root)
