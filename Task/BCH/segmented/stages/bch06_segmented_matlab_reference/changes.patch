+plt.figure(figsize=(7,3)); plt.bar(['wrong block info','wrong original payload','filler only'],[12,9,3]); plt.tight_layout(); plt.savefig(stage / 'plots/bch06_double_error_classification.png',dpi=140); plt.close()
